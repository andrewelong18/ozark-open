{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/betting/**",
              "components/core/**",
              "components/modules/**",
              "components/navigation/**",
              "ui_kits/sportsbook/**",
              "ui_kits/sportsbook/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Azalea|Montserrat))/i]",
        "message": "Font not provided by the design system. Available: Azalea, Montserrat."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|uppercase|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, icon, uppercase, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|indigo|gold|green|red|amber|solid)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'indigo' | 'gold' | 'green' | 'red' | 'amber' | 'solid'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BetRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|description|odds|status|outcome|oddsDetail|stake|placed|stakeError|onStakeChange|onPlace|style|key|ref|className|style|children)$/]",
        "message": "<BetRow> doesn't accept that prop. Declared props: number, description, odds, status, outcome, oddsDetail, stake, placed, stakeError, onStakeChange, onPlace, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='BetRow'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:open|closed|resolved)$/]",
        "message": "<BetRow> status must be one of 'open' | 'closed' | 'resolved'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BetRow'] > JSXAttribute[name.name='outcome'] > Literal[value!=/^(?:hit|miss|push|void)$/]",
        "message": "<BetRow> outcome must be one of 'hit' | 'miss' | 'push' | 'void'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BudgetModule'] > JSXAttribute > JSXIdentifier[name!=/^(?:wagered|entryFee|betCount|minBets|maxBets|compact|style|key|ref|className|style|children)$/]",
        "message": "<BudgetModule> doesn't accept that prop. Declared props: wagered, entryFee, betCount, minBets, maxBets, compact, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|leadingIcon|trailingIcon|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, leadingIcon, trailingIcon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|gold|secondary|ghost|destructive)$/]",
        "message": "<Button> variant must be one of 'primary' | 'gold' | 'secondary' | 'ghost' | 'destructive'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:elevated|accent|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: elevated, accent, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComplianceBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|title|children|action|style|key|ref|className|style|children)$/]",
        "message": "<ComplianceBanner> doesn't accept that prop. Declared props: tone, title, children, action, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ComplianceBanner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:warning|info|success)$/]",
        "message": "<ComplianceBanner> tone must be one of 'warning' | 'info' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='EmptyState'] > JSXAttribute > JSXIdentifier[name!=/^(?:glyph|title|message|action|style|key|ref|className|style|children)$/]",
        "message": "<EmptyState> doesn't accept that prop. Declared props: glyph, title, message, action, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute > JSXIdentifier[name!=/^(?:brand|markSrc|nav|active|user|onNavigate|maxWidth|navStyle|style|key|ref|className|style|children)$/]",
        "message": "<Header> doesn't accept that prop. Declared props: brand, markSrc, nav, active, user, onNavigate, maxWidth, navStyle, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Header'] > JSXAttribute[name.name='navStyle'] > Literal[value!=/^(?:pill|underline)$/]",
        "message": "<Header> navStyle must be one of 'pill' | 'underline'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|invalid|disabled|leading|trailing|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: size, invalid, disabled, leading, trailing."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoneyDisplay'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|cents|pl|onDark|size|weight|style|key|ref|className|style|children)$/]",
        "message": "<MoneyDisplay> doesn't accept that prop. Declared props: value, cents, pl, onDark, size, weight, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoneyDisplay'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:xs|sm|md|lg|xl)$/]",
        "message": "<MoneyDisplay> size must be one of 'xs' | 'sm' | 'md' | 'lg' | 'xl'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MoneyDisplay'] > JSXAttribute[name.name='weight'] > Literal[value!=/^(?:regular|medium|semibold|bold)$/]",
        "message": "<MoneyDisplay> weight must be one of 'regular' | 'medium' | 'semibold' | 'bold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddsChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:odds|size|detail|style|key|ref|className|style|children)$/]",
        "message": "<OddsChip> doesn't accept that prop. Declared props: odds, size, detail, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OddsChip'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<OddsChip> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutcomeBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:outcome|size|style|key|ref|className|style|children)$/]",
        "message": "<OutcomeBadge> doesn't accept that prop. Declared props: outcome, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutcomeBadge'] > JSXAttribute[name.name='outcome'] > Literal[value!=/^(?:hit|miss|push|void)$/]",
        "message": "<OutcomeBadge> outcome must be one of 'hit' | 'miss' | 'push' | 'void'."
      },
      {
        "selector": "JSXOpeningElement[name.name='OutcomeBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<OutcomeBadge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='RulesCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:entryFee|maxSingle|maxSelf|minBets|maxBets|style|key|ref|className|style|children)$/]",
        "message": "<RulesCard> doesn't accept that prop. Declared props: entryFee, maxSingle, maxSelf, minBets, maxBets, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StakeInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|placed|error|disabled|onChange|onPlace|style|key|ref|className|style|children)$/]",
        "message": "<StakeInput> doesn't accept that prop. Declared props: value, max, placed, error, disabled, onChange, onPlace, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|money|cents|caption|feature|style|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: label, value, money, cents, caption, feature, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|style|key|ref|className|style|children)$/]",
        "message": "<StatusBadge> doesn't accept that prop. Declared props: status, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusBadge'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:open|closed|resolved)$/]",
        "message": "<StatusBadge> status must be one of 'open' | 'closed' | 'resolved'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
