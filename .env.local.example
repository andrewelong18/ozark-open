NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Leaderboard (Sprint 8) — read-only Google Sheets service account. Create a
# service account, enable the Sheets API, and share the "Sportsbook Leaderboard"
# sheet with the account's email as Viewer. Server-only: no NEXT_PUBLIC_ prefix.
GOOGLE_SERVICE_ACCOUNT_EMAIL=name@project.iam.gserviceaccount.com
# Paste the private key from the service-account JSON, newlines escaped as \n
# (wrap the whole value in quotes).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# The leaderboard spreadsheet's ID (the long token in its URL).
GOOGLE_SHEET_ID=your_leaderboard_spreadsheet_id

# --- Agent automation (see docs/AGENT_AUTOMATION.md) --------------------------
# These let Claude Code do the manual Supabase/Vercel chores itself. All free
# tier. Set them in your environment (or here — .env* is gitignored); the app
# itself does NOT read them, so leaving them blank never breaks the site.
#
# Supabase personal access token (Account -> Access Tokens). Powers the Supabase
# MCP in .mcp.json (apply migrations, data edits) and scripts/prod-auth-config.sh.
SUPABASE_ACCESS_TOKEN=sbp_...
# Vercel token (Account Settings -> Tokens). Powers `vercel env add` for #66,
# since the official Vercel MCP can't manage env vars.
VERCEL_TOKEN=
