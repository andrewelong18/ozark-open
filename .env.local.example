NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# Leaderboard (Sprint 8) — read-only Google Sheets service account. Create a
# service account, enable the Sheets API, and share the "Sportsbook Leaderboard"
# sheet with the account's email as Viewer. Server-only: no NEXT_PUBLIC_ prefix.
GOOGLE_SERVICE_ACCOUNT_EMAIL=name@project.iam.gserviceaccount.com
# Paste the private key from the service-account JSON, newlines escaped as \n
# (wrap the whole value in quotes).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# The leaderboard spreadsheet's ID (the long token in its URL).
GOOGLE_SHEET_ID=your_leaderboard_spreadsheet_id
