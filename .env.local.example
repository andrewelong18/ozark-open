# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored; never commit real secrets.

# --- Supabase ---
# Find these at: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# --- Google Sheets API (Phase 8 — leaderboard mirror; not needed until then) ---
# Service account with read-only access to the scoring workbook.
# GOOGLE_SHEETS_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_SHEETS_PRIVATE_KEY=
# GOOGLE_SHEETS_LEADERBOARD_ID=
